generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum CategoryType {
  INCOME
  EXPENSE
}

// Categories table
model Category {
  id          String    @id @default(cuid())
  userId      String
  name        String
  type        CategoryType
  createdAt   DateTime  @default(now())

  transactions Transaction[]
}

// Transactions table
model Transaction { 
  id          String    @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Decimal
  description String?
  date        DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
}